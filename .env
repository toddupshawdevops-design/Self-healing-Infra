# .env.example — copy to .env and fill in values

AWS_DEFAULT_REGION=eu-north-1
AWS_PROFILE=default

PROJECT_NAME=self-healing-infra
ENVIRONMENT=dev

# Set by Terraform outputs
ALB_DNS_NAME=self-healing-infra-alb-dev-1018299559.eu-north-1.elb.amazonaws.com
ASG_NAME=self-healing-infra-asg-dev
SNS_TOPIC_ARN=self-healing-infra-alb-dev-1018299559.eu-north-1.elb.amazonaws.com
LOGS_BUCKET=self-healing-infra-logs-dev-897253013073
# Store in SSM Parameter Store, not here
# aws ssm put-parameter --name /self-healing-infra/dev/slack-webhook-url --value "https://hooks.slack.com/..." --type SecureString
SLACK_WEBHOOK_SSM=/self-healing-infra/dev/slack-webhook-url

DRY_RUN=false
